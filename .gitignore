## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml
*.swp
*.sln.user

# NuGet Packages
*.nupkg
*.snupkg
.nuget/

# Cloo build artifacts
build/
dist/

# Local OpenCL cache
cache/
cache/kernels/

# Output directories
input/
output/
temp/
logs/

# Environment files
.env
.env.local

# macOS
.DS_Store

# Linux
.directory

# Windows
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Test results
TestResults/
*.trx

# Coverage reports
coverage/
OpenCover/

# Performance profiling
*.etl
*.diagsession
